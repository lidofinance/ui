{
  "$schema": "https://turbo.build/schema.json",
  "ui": "tui",
  "globalDependencies": ["babel.config.json", "tsconfig.base.json"],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "inputs": ["src/**", "styles/**", "scripts/**", "rollup.config.mjs", "postcss.config.js", "tsconfig.json", "tsconfig.production.json", "package.json"]
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"],
      "inputs": ["src/**", ".storybook/**"]
    },
    "test": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "lint:css": {},
    "types": {}
  }
}

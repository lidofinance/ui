{
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "type": "module",
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "types": "turbo run types",
    "build-storybook": "turbo run build-storybook",
    "storybook:ui": "yarn workspace @lidofinance/lido-ui dev",
    "storybook:landing": "yarn workspace @lidofinance/lido-landing-ui dev",
    "storybook:widget": "yarn workspace @lidofinance/lido-app-ui dev",
    "release": "multi-semantic-release",
    "prepare": "git config core.hooksPath .git-hooks || echo 'Not in a git repo'"
  },
  "release": {
    "branches": [
      "main",
      {
        "name": "alpha-release",
        "channel": "alpha",
        "prerelease": "alpha"
      },
      {
        "name": "feature/we-2376-migrate-lido-ui-to-monorepo-structure",
        "channel": "alpha",
        "prerelease": "alpha"
      }
    ],
    "plugins": [
      [
        "@semantic-release/commit-analyzer",
        {
          "preset": "conventionalcommits"
        }
      ]
    ]
  },
  "multi-release": {
    "tagFormat": "${name}@${version}",
    "sequentialInit": true,
    "ignorePrivate": true,
    "deps": {
      "bump": "satisfy",
      "release": "patch",
      "prefix": "^"
    }
  },
  "lint-staged": {
    "*.{ts,tsx,js,cjs,mjs}": "eslint --fix",
    "*.css": "stylelint --fix"
  },
  "devDependencies": {
    "@commitlint/cli": "19.8.0",
    "@commitlint/config-conventional": "19.8.0",
    "@lidofinance/multi-semantic-release": "^1.0.0",
    "@semantic-release/commit-analyzer": "13.0.1",
    "@semantic-release/github": "12.0.8",
    "@semantic-release/npm": "13.1.5",
    "@semantic-release/release-notes-generator": "14.1.1",
    "@storybook/react": "8.6.12",
    "@storybook/react-webpack5": "8.6.12",
    "@typescript-eslint/eslint-plugin": "5.62.0",
    "@typescript-eslint/parser": "5.62.0",
    "autoprefixer": "10.4.21",
    "conventional-changelog-conventionalcommits": "4.6.3",
    "eslint": "8.46.0",
    "eslint-config-prettier": "9.0.0",
    "eslint-import-resolver-typescript": "4.4.4",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-node": "11.1.0",
    "eslint-plugin-prettier": "5.2.6",
    "eslint-plugin-react": "7.33.1",
    "eslint-plugin-react-hooks": "5.2.0",
    "eslint-plugin-storybook": "0.12.0",
    "lint-staged": "15.5.1",
    "postcss": "8.5.3",
    "postcss-custom-media": "11.0.5",
    "postcss-import": "16.1.0",
    "postcss-nested": "7.0.2",
    "prettier": "3.5.3",
    "stylelint": "15.11.0",
    "stylelint-config-standard": "34.0.0",
    "stylelint-prettier": "4.1.0",
    "turbo": "2.10.4",
    "typescript": "5.8.3"
  },
  "packageManager": "yarn@4.9.0"
}

{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "typeRoots": ["../../node_modules/@types"],
    "paths": {
      "react": ["../../node_modules/@types/react"],
      "cakeinpanic-shared": ["../shared/src"],
      "cakeinpanic-shared/*": ["../shared/src/*"]
    },
    "outDir": "./dist/types"
  },
  "include": [
    "**/*.d.ts",
    "src/**/*.ts",
    "src/**/*.tsx"
  ],
  "exclude": ["node_modules", "dist"]
}

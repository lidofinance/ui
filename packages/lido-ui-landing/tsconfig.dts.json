{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "typeRoots": ["./@types", "../../node_modules/@types"],
    "paths": {
      "react": ["../../node_modules/@types/react"],
      "packages/*": ["./src/*"],
      "@lido-ui/shared": ["../shared/dist/types"],
      "@lido-ui/shared/*": ["../shared/dist/types/*"]
    }
  },
  "include": ["global.d.ts", "src/**/*.ts", "src/**/*.tsx"]
}

{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "emitDeclarationOnly": true,
    "outDir": "./dist/types",
    "rootDir": "src",
    "paths": {
      "react": ["../../node_modules/@types/react"],
      "packages/*": ["./src/*"],
      "cakeinpanic-shared": ["../shared/dist/types"],
      "cakeinpanic-shared/*": ["../shared/dist/types/*"]
    }
  },
  "include": ["global.d.ts", "src/**/*.ts", "src/**/*.tsx"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}

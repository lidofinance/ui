{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "react": ["../../node_modules/@types/react"],
      "packages/*": ["./src/*"],
      "@lido-ui/shared": ["../shared/src"],
      "@lido-ui/shared/*": ["../shared/src/*"]
    },
    "outDir": "./dist/types"
  },
  "include": [
    "**/*.d.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.ts",
    "src/**/*.tsx",
    "global.d.ts"
  ],
  "exclude": ["node_modules", "dist"]
}

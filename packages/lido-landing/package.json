{
  "name": "@lidofinance/lido-landing-ui",
  "version": "0.1.0",
  "homepage": "https://github.com/lidofinance/ui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lidofinance/ui.git"
  },
  "bugs": {
    "url": "https://github.com/lidofinance/ui/issues"
  },
  "type": "module",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.mjs",
      "require": "./dist/cjs/index.js"
    },
    "./index.css": "./dist/index.css",
    "./styles/*": "./dist/styles/*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "rm -rf dist && rollup -c && tsc --project tsconfig.production.json && cp dist/esm/index.css dist/index.css && node scripts/patch-shared-types.mjs",
    "dev": "storybook dev -p 5556",
    "build-storybook": "storybook build --output-dir storybook-static",
    "test": "vitest run --passWithNoTests",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "lint:css": "stylelint '**/*.css'",
    "lint:css:fix": "stylelint --fix '**/*.css'",
    "types": "tsc --noEmit",
    "icons:convert": "node ./src/icons/converter/index.cjs",
    "css-variables:generate": "node ./scripts/generate-css-variables.mjs"
  },
  "peerDependencies": {
    "@inline-svg-unique-id/react": "1.2.3",
    "react": "16 || 17 || 18",
    "react-dom": "16 || 17 || 18"
  },
  "dependencies": {
    "@lidofinance/lido-shared-ui": "*",
    "classnames": "2.5.1",
    "postcss-mixins": "11.0.3",
    "react-collapsed": "4.2.0",
    "react-jazzicon": "1.0.4",
    "react-toastify": "11.0.5",
    "react-transition-group": "4",
    "ua-parser-js": "2.0.3",
    "use-callback-ref": "1.2.5"
  },
  "devDependencies": {
    "@babel/preset-env": "7.26.9",
    "@babel/preset-react": "7.26.3",
    "@babel/preset-typescript": "7.27.0",
    "@csstools/postcss-global-data": "3.0.0",
    "@inline-svg-unique-id/react": "1.2.3",
    "@rollup/plugin-babel": "6.0.4",
    "@rollup/plugin-commonjs": "28.0.3",
    "@rollup/plugin-node-resolve": "16.0.1",
    "@storybook/addon-actions": "8.6.12",
    "@storybook/addon-docs": "8.6.12",
    "@storybook/addon-essentials": "8.6.12",
    "@storybook/addon-webpack5-compiler-swc": "3.0.0",
    "@storybook/cli": "8.6.12",
    "@storybook/react": "8.6.12",
    "@storybook/react-webpack5": "8.6.12",
    "@storybook/test": "8.6.12",
    "@storybook/theming": "8.6.12",
    "@svgr/core": "8.1.0",
    "@svgr/plugin-jsx": "8.1.0",
    "@svgr/plugin-prettier": "8.1.0",
    "@svgr/plugin-svgo": "5.5.0",
    "@testing-library/react": "15.0.7",
    "@types/react": "18.2.24",
    "@types/react-dom": "18.2.9",
    "@types/react-transition-group": "4.4.12",
    "@types/ua-parser-js": "0.7.39",
    "@vitejs/plugin-react": "^4.0.0",
    "babel-plugin-react-inline-svg-unique-id": "1.5.0",
    "browserslist": "4.24.5",
    "jsdom": "^25.0.0",
    "postcss-loader": "8.1.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "rollup": "3.29.5",
    "rollup-plugin-copy": "3.5.0",
    "rollup-plugin-postcss": "4.0.2",
    "storybook": "8.6.12",
    "tslib": "2.3.1",
    "vitest": "^3.0.0"
  },
  "publishConfig": {
    "provenance": true,
    "access": "public"
  }
}

{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "react": [ "./node_modules/@types/react" ]
    }
  },
  "include": [
    "**/*.d.ts",
    ".storybook/**/*.ts",
    ".storybook/**/*.tsx",
    "packages/**/*.test.ts",
    "packages/**/*.test.tsx",
    "packages/**/*.stories.ts",
    "packages/**/*.stories.tsx",
    "packages/**/*.ts",
    "packages/**/*.tsx",
    "global.d.ts"
  ],
  "exclude": ["node_modules"]
}
